{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afox.moe/dpsandbox/dps-manifest.schema.json",
  "title": "Datapack Sandbox manifest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "include": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/stringArray" }
      ]
    },
    "version": { "type": "string" },
    "versions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "unsupported": {
      "type": "string",
      "enum": ["warn", "warning", "ignore", "silent", "error", "strict"]
    },
    "seed": { "type": "integer" },
    "failOnMissingResources": { "type": "boolean" },
    "packs": {
      "oneOf": [
        { "$ref": "#/$defs/stringArray" },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/stringArray" }
        }
      ]
    },
    "world": { "$ref": "#/$defs/worldFixture" },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    },
    "assertions": {
      "type": "array",
      "items": { "$ref": "#/$defs/assertion" }
    }
  },
  "anyOf": [
    { "required": ["packs"] },
    { "required": ["include"] }
  ],
  "oneOf": [
    { "required": ["version"], "not": { "required": ["versions"] } },
    { "required": ["versions"], "not": { "required": ["version"] } },
    { "not": { "anyOf": [{ "required": ["version"] }, { "required": ["versions"] }] } }
  ],
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "position": {
      "type": "array",
      "prefixItems": [
        { "type": "number" },
        { "type": "number" },
        { "type": "number" }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "blockPos": {
      "type": "array",
      "prefixItems": [
        { "type": "integer" },
        { "type": "integer" },
        { "type": "integer" }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "chunk": {
      "type": "array",
      "prefixItems": [
        { "type": "integer" },
        { "type": "integer" }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "spawnPoint": {
      "type": "object",
      "properties": {
        "pos": { "$ref": "#/$defs/position" },
        "position": { "$ref": "#/$defs/position" },
        "dimension": { "type": "string" },
        "angle": { "type": "number" },
        "forced": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "worldBorder": {
      "type": "object",
      "properties": {
        "centerX": { "type": "number" },
        "centerZ": { "type": "number" },
        "size": { "type": "number", "minimum": 1 },
        "targetSize": { "type": "number", "minimum": 1 },
        "lerpTimeSeconds": { "type": "integer", "minimum": 0 },
        "damageBuffer": { "type": "number" },
        "damageAmount": { "type": "number" },
        "warningDistance": { "type": "integer", "minimum": 0 },
        "warningTime": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "worldFixture": {
      "type": "object",
      "properties": {
        "extends": {
          "oneOf": [
            { "type": "string" },
            { "$ref": "#/$defs/stringArray" }
          ]
        },
        "fixture": {
          "oneOf": [
            { "type": "string" },
            { "$ref": "#/$defs/stringArray" }
          ]
        },
        "fixtures": {
          "oneOf": [
            { "type": "string" },
            { "$ref": "#/$defs/stringArray" }
          ]
        },
        "gameTime": { "type": "integer" },
        "time": { "type": "integer" },
        "dayTime": { "type": "integer" },
        "seed": { "type": "integer" },
        "difficulty": { "type": "string" },
        "defaultGameMode": { "type": "string" },
        "defaultGamemode": { "type": "string" },
        "weather": { "type": "string", "enum": ["clear", "rain", "thunder"] },
        "weatherDuration": { "type": "integer", "minimum": 0 },
        "worldSpawn": { "$ref": "#/$defs/spawnPoint" },
        "worldBorder": { "$ref": "#/$defs/worldBorder" },
        "forcedChunks": {
          "type": "array",
          "items": { "$ref": "#/$defs/chunk" }
        },
        "biomes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["pos", "id"],
            "properties": {
              "pos": { "$ref": "#/$defs/blockPos" },
              "id": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/blockFixture" }
        },
        "entities": {
          "type": "array",
          "items": { "$ref": "#/$defs/entityFixture" }
        },
        "players": {
          "type": "array",
          "items": { "$ref": "#/$defs/playerFixture" }
        },
        "teams": {
          "type": "array",
          "items": { "$ref": "#/$defs/teamFixture" }
        },
        "bossbars": {
          "type": "array",
          "items": { "$ref": "#/$defs/bossbarFixture" }
        },
        "scores": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["target", "objective", "value"],
            "properties": {
              "target": { "type": "string" },
              "objective": { "type": "string" },
              "value": { "type": "integer" },
              "criteria": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "storage": {
          "type": "object",
          "additionalProperties": true
        },
        "storages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "value"],
            "properties": {
              "id": { "type": "string" },
              "value": true
            },
            "additionalProperties": false
          }
        },
        "gamerules": {
          "type": "object",
          "additionalProperties": true
        },
        "save": { "type": "object" },
        "saves": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "additionalProperties": false
    },
    "blockFixture": {
      "type": "object",
      "required": ["pos", "id"],
      "properties": {
        "pos": { "$ref": "#/$defs/blockPos" },
        "id": { "type": "string" },
        "properties": {
          "type": "object",
          "additionalProperties": true
        },
        "nbt": true
      },
      "additionalProperties": false
    },
    "entityFixture": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "pos": { "$ref": "#/$defs/position" },
        "tags": { "$ref": "#/$defs/stringArray" },
        "nbt": true,
        "yaw": { "type": "number" },
        "pitch": { "type": "number" }
      },
      "additionalProperties": false
    },
    "itemFixture": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "item": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 },
        "components": { "type": "object" },
        "nbt": true
      },
      "additionalProperties": false
    },
    "playerEffectFixture": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": { "type": "string" },
            "duration": { "type": "integer" },
            "amplifier": { "type": "integer" },
            "hideParticles": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },
    "playerFixture": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "pos": { "$ref": "#/$defs/position" },
        "position": { "$ref": "#/$defs/position" },
        "dimension": { "type": "string" },
        "gameMode": { "type": "string" },
        "gamemode": { "type": "string" },
        "xp": { "type": "integer" },
        "health": { "type": "number" },
        "food": { "type": "integer" },
        "selectedSlot": { "type": "integer", "minimum": 0 },
        "inventory": {
          "type": "array",
          "items": { "$ref": "#/$defs/itemFixture" }
        },
        "recipes": { "$ref": "#/$defs/stringArray" },
        "stats": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/playerEffectFixture" }
        },
        "spawn": { "$ref": "#/$defs/spawnPoint" }
      },
      "additionalProperties": false
    },
    "teamFixture": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "displayName": { "type": "string" },
        "members": { "$ref": "#/$defs/stringArray" },
        "options": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "bossbarFixture": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "value": { "type": "integer" },
        "max": { "type": "integer", "minimum": 1 },
        "color": { "type": "string" },
        "style": { "type": "string" },
        "visible": { "type": "boolean" },
        "players": { "$ref": "#/$defs/stringArray" }
      },
      "additionalProperties": false
    },
    "eventStep": {
      "type": "object",
      "required": ["player", "type"],
      "properties": {
        "player": { "type": "string" },
        "type": { "type": "string" },
        "item": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 },
        "components": { "type": "object" },
        "nbt": true,
        "entity": { "type": "string" },
        "block": { "type": "string" },
        "recipe": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "damageSource": { "type": "string" },
        "damageType": { "type": "string" },
        "amount": { "type": "number" },
        "damage": { "type": "number" },
        "key": { "type": "string" },
        "button": { "type": "string" },
        "mouseButton": { "type": "string" },
        "action": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "additionalProperties": true,
      "oneOf": [
        { "required": ["load"] },
        { "required": ["ticks"] },
        { "required": ["function"] },
        { "required": ["command"] },
        { "required": ["commands"] },
        { "required": ["functionText"] },
        { "required": ["mcfunction"] },
        { "required": ["player"] },
        { "required": ["block"] },
        { "required": ["event"] },
        { "required": ["snapshot"] },
        { "required": ["trace"] },
        { "required": ["reset"] },
        { "required": ["loot"] }
      ],
      "properties": {
        "load": { "type": "boolean" },
        "ticks": { "type": "integer", "minimum": 0 },
        "function": { "type": "string" },
        "command": { "type": "string" },
        "commands": { "$ref": "#/$defs/stringArray" },
        "functionText": { "type": "string" },
        "mcfunction": { "type": "string" },
        "source": { "type": "string" },
        "player": { "type": "object" },
        "block": { "type": "object" },
        "event": { "$ref": "#/$defs/eventStep" },
        "snapshot": { "$ref": "#/$defs/stepOutput" },
        "trace": { "$ref": "#/$defs/stepOutput" },
        "reset": { "type": "boolean" },
        "allowFailure": { "type": "boolean" },
        "loot": { "$ref": "#/$defs/lootRequest" }
      }
    },
    "stepOutput": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "file": { "type": "string" },
            "output": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },
    "lootRequest": {
      "type": "object",
      "required": ["table"],
      "properties": {
        "table": { "type": "string" },
        "context": { "type": "string" },
        "player": { "type": "string" },
        "seed": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        { "required": ["score"] },
        { "required": ["storage"] },
        { "required": ["entityCount"] },
        { "required": ["world"] },
        { "required": ["player"] },
        { "required": ["team"] },
        { "required": ["bossbar"] },
        { "required": ["block"] },
        { "required": ["advancement"] },
        { "required": ["predicate"] },
        { "required": ["loot"] },
        { "required": ["item"] },
        { "required": ["trace"] },
        { "required": ["eventTrace"] },
        { "required": ["diagnostic"] },
        { "required": ["snapshotDiff"] },
        { "required": ["output"] }
      ],
      "properties": {
        "score": { "$ref": "#/$defs/scoreAssertion" },
        "storage": { "$ref": "#/$defs/storageAssertion" },
        "entityCount": { "$ref": "#/$defs/entityCountAssertion" },
        "world": { "$ref": "#/$defs/worldAssertion" },
        "player": { "$ref": "#/$defs/playerAssertion" },
        "team": { "$ref": "#/$defs/teamAssertion" },
        "bossbar": { "$ref": "#/$defs/bossbarAssertion" },
        "block": { "$ref": "#/$defs/blockAssertion" },
        "advancement": { "$ref": "#/$defs/advancementAssertion" },
        "predicate": { "$ref": "#/$defs/predicateAssertion" },
        "loot": { "$ref": "#/$defs/lootAssertion" },
        "item": { "$ref": "#/$defs/itemAssertion" },
        "trace": { "$ref": "#/$defs/traceAssertion" },
        "eventTrace": { "$ref": "#/$defs/eventTraceAssertion" },
        "diagnostic": { "$ref": "#/$defs/diagnosticAssertion" },
        "snapshotDiff": { "$ref": "#/$defs/snapshotDiffAssertion" },
        "output": { "$ref": "#/$defs/outputAssertion" }
      }
    },
    "scoreAssertion": {
      "type": "object",
      "required": ["target", "objective"],
      "anyOf": [
        { "required": ["equals"] },
        { "required": ["min"] },
        { "required": ["max"] }
      ],
      "properties": {
        "target": { "type": "string" },
        "objective": { "type": "string" },
        "equals": { "type": "integer" },
        "min": { "type": "integer" },
        "max": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "storageAssertion": {
      "type": "object",
      "required": ["id"],
      "anyOf": [
        { "required": ["equals"] },
        { "required": ["exists"] },
        { "required": ["missing"] }
      ],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" },
        "equals": true,
        "exists": { "type": "boolean" },
        "missing": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "worldAssertion": {
      "type": "object",
      "properties": {
        "gameTime": { "type": "integer" },
        "dayTime": { "type": "integer" },
        "time": { "type": "integer" },
        "seed": { "type": "integer" },
        "weather": { "type": "string" },
        "weatherDuration": { "type": "integer" },
        "difficulty": { "type": "string" },
        "defaultGameMode": { "type": "string" },
        "defaultGamemode": { "type": "string" },
        "forcedChunk": { "$ref": "#/$defs/chunk" },
        "biome": {
          "type": "object",
          "required": ["pos", "id"],
          "properties": {
            "pos": { "$ref": "#/$defs/blockPos" },
            "id": { "type": "string" }
          },
          "additionalProperties": false
        },
        "worldSpawn": { "$ref": "#/$defs/spawnPoint" },
        "worldBorder": { "$ref": "#/$defs/worldBorder" }
      },
      "additionalProperties": false
    },
    "advancementAssertion": {
      "type": "object",
      "required": ["player", "id"],
      "properties": {
        "player": { "type": "string" },
        "id": { "type": "string" },
        "done": { "type": "boolean" },
        "criterion": { "type": "string" },
        "criterionDone": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "predicateAssertion": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "player": { "type": "string" },
        "equals": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "lootAssertion": {
      "type": "object",
      "required": ["table"],
      "properties": {
        "table": { "type": "string" },
        "context": { "type": "string" },
        "player": { "type": "string" },
        "seed": { "type": "integer" },
        "count": { "type": "integer", "minimum": 0 },
        "item": { "type": "string" }
      },
      "additionalProperties": false
    },
    "entityCountAssertion": {
      "type": "object",
      "anyOf": [
        { "required": ["equals"] },
        { "required": ["min"] },
        { "required": ["max"] }
      ],
      "properties": {
        "type": { "type": "string" },
        "tag": { "type": "string" },
        "equals": { "type": "integer", "minimum": 0 },
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "playerAssertion": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "exists": { "type": "boolean" },
        "xp": { "type": "integer" },
        "inventoryCount": { "type": "integer", "minimum": 0 },
        "dimension": { "type": "string" },
        "gameMode": { "type": "string" },
        "gamemode": { "type": "string" },
        "health": { "type": "number" },
        "food": { "type": "integer" },
        "selectedSlot": { "type": "integer", "minimum": 0 },
        "recipe": { "type": "string" },
        "effect": { "type": "string" },
        "stat": {
          "type": "object",
          "required": ["id", "equals"],
          "properties": {
            "id": { "type": "string" },
            "equals": { "type": "integer" }
          },
          "additionalProperties": false
        },
        "position": { "$ref": "#/$defs/position" },
        "lastInput": {
          "type": "object",
          "properties": {
            "device": { "type": "string" },
            "code": { "type": "string" },
            "action": { "type": "string" }
          },
          "additionalProperties": false
        },
        "spawn": { "$ref": "#/$defs/spawnPoint" }
      },
      "additionalProperties": false
    },
    "teamAssertion": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "exists": { "type": "boolean" },
        "displayName": { "type": "string" },
        "member": { "type": "string" },
        "memberCount": { "type": "integer", "minimum": 0 },
        "option": {
          "type": "object",
          "required": ["name", "equals"],
          "properties": {
            "name": { "type": "string" },
            "equals": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "bossbarAssertion": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "exists": { "type": "boolean" },
        "name": { "type": "string" },
        "value": { "type": "integer" },
        "max": { "type": "integer", "minimum": 1 },
        "color": { "type": "string" },
        "style": { "type": "string" },
        "visible": { "type": "boolean" },
        "player": { "type": "string" }
      },
      "additionalProperties": false
    },
    "pathExpectation": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "equals": {},
        "exists": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "blockAssertion": {
      "type": "object",
      "required": ["pos"],
      "properties": {
        "pos": { "$ref": "#/$defs/blockPos" },
        "id": { "type": "string" },
        "exists": { "type": "boolean" },
        "nbt": { "$ref": "#/$defs/pathExpectation" }
      },
      "additionalProperties": false
    },
    "itemAssertion": {
      "type": "object",
      "required": ["player"],
      "properties": {
        "player": { "type": "string" },
        "id": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 },
        "minCount": { "type": "integer", "minimum": 0 },
        "maxCount": { "type": "integer", "minimum": 0 },
        "slot": { "type": "integer", "minimum": 0 },
        "exists": { "type": "boolean" },
        "components": { "$ref": "#/$defs/pathExpectation" },
        "nbt": { "$ref": "#/$defs/pathExpectation" }
      },
      "additionalProperties": false
    },
    "traceAssertion": {
      "type": "object",
      "properties": {
        "command": { "type": "string" },
        "root": { "type": "string" },
        "contains": { "type": "string" },
        "success": { "type": "boolean" },
        "count": { "type": "integer", "minimum": 0 },
        "fileContains": { "type": "string" },
        "function": { "type": "string" }
      },
      "additionalProperties": false
    },
    "outputAssertion": {
      "type": "object",
      "properties": {
        "command": { "type": "string" },
        "channel": { "type": "string" },
        "target": { "type": "string" },
        "targets": { "$ref": "#/$defs/stringArray" },
        "text": { "type": "string" },
        "equals": { "type": "string" },
        "contains": { "type": "string" },
        "normalizedText": { "type": "string" },
        "normalizedEquals": { "type": "string" },
        "normalizedContains": { "type": "string" },
        "payloadPath": { "type": "string" },
        "payloadEquals": {},
        "payload": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "equals": {}
          },
          "additionalProperties": false
        },
        "segment": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "equals": { "type": "string" },
            "contains": { "type": "string" },
            "normalizedText": { "type": "string" },
            "normalizedEquals": { "type": "string" },
            "normalizedContains": { "type": "string" },
            "color": { "type": "string" },
            "bold": { "type": "boolean" },
            "italic": { "type": "boolean" },
            "underlined": { "type": "boolean" },
            "strikethrough": { "type": "boolean" },
            "obfuscated": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "count": { "type": "integer", "minimum": 0 },
        "order": { "type": "integer", "minimum": 1 }
      },
