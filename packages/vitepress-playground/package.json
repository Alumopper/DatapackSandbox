{
  "name": "@datapack-sandbox/vitepress-playground",
  "version": "0.2.0",
  "description": "Persistent, browser-only MCFunction notebook cells for VitePress sites",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cell": {
      "types": "./dist/cell.d.ts",
      "import": "./dist/cell.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "prepare:worker": "node scripts/prepare-worker.mjs",
    "check:size": "node scripts/check-worker-size.mjs",
    "build": "npm run prepare:worker && vite build && vue-tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:e2e": "node tests/e2e/prepare.mjs && playwright test",
    "e2e:fixture": "vite --config tests/e2e/vite.config.ts",
    "check": "npm run prepare:worker && vue-tsc --noEmit && vitest run && vite build && npm run check:size && vue-tsc --emitDeclarationOnly && npm pack --dry-run"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/language": "^6.11.3",
    "@codemirror/lint": "^6.9.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "fflate": "0.8.2",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@playwright/test": "^1.55.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^6.1.0",
    "vitest": "^3.2.4",
    "vue": "^3.5.21",
    "vue-tsc": "^3.0.6"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
